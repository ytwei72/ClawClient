    "@typescript-eslint/parser": "^6.9.1",
    "microbundle": "^0.15.1",
    "prettier": "^3.0.3",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@openim/protocol": "^0.0.7-alpha.1",
    "base64-arraybuffer": "^1.0.2",
    "loglevel": "^1.9.2",
    "spark-md5": "^3.0.2"
  }
