{
  "name": "@openim/client-sdk",
  "version": "3.8.3",
  "description": "JavaScript/TypeScript Client SDK for OpenIM",
  "source": "src/index.ts",
  "main": "lib/index.js",
  "unpkg": "lib/index.umd.js",
  "module": "lib/index.es.js",
  "jsdelivr": "lib/index.umd.js",
  "types": "lib/index.d.ts",
  "scripts": {
